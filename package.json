{
  "name": "@screenly-labs/signage-kit",
  "version": "2026.7.0",
  "description": "Shared build pipeline, degraded-mode layer, and base Tailwind preset for Screenly-Labs signage apps.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Screenly-Labs/signage-kit.git"
  },
  "homepage": "https://github.com/Screenly-Labs/signage-kit#readme",
  "bugs": "https://github.com/Screenly-Labs/signage-kit/issues",
  "exports": {
    "./polyfills": "./src/polyfills.ts",
    "./gate": { "types": "./src/gate.d.ts", "default": "./src/gate.js" },
    "./build": { "types": "./src/build.d.ts", "default": "./src/build.js" },
    "./styles/preset.css": "./styles/preset.css",
    "./styles/degraded.css": "./styles/degraded.css"
  },
  "files": ["src", "styles"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --error-on-warnings .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "test": "bun test"
  },
  "peerDependencies": {
    "@csstools/postcss-cascade-layers": "^6",
    "browserslist": "^4",
    "esbuild": "^0.28",
    "lightningcss": "^1.32",
    "postcss": "^8"
  },
  "peerDependenciesMeta": {
    "@csstools/postcss-cascade-layers": { "optional": true },
    "postcss": { "optional": true }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@csstools/postcss-cascade-layers": "^6.0.0",
    "browserslist": "^4.28.6",
    "bun-types": "^1.3.14",
    "esbuild": "^0.28.1",
    "lightningcss": "^1.32.0",
    "postcss": "^8.5.18",
    "typescript": "^5.7.3"
  }
}
